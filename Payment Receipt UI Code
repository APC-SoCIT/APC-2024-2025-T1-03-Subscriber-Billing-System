<!DOCTYPE html>
<html>
  <head>
    <title>Payment Success</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <style>
      body {
        font-family: "Inter", Arial, sans-serif;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100vh;
        background-color: #f4f5fb;
        color: #38517e;
        padding: 20px;
      }
      .receipt-container {
        background: #ffffff;
        padding: 25px;
        border-radius: 10px;
        box-shadow: 0 5px 10px rgba(0, 0, 0, 0.1);
        text-align: center;
        width: 350px;
      }
      .success-icon {
        margin-top: 18px;
        width: 60px;
        height: 60px;
      }
      h2 {
        color: #38517e;
        margin-top: 25px;
        font-size: 15px; 
        font-weight: 600;
      }
      .company-name {
        margin-top: 18px;
        font-size: 14px; 
        font-weight: 500;
      }
      .separator {
        margin: 60px; 
      }
      .details {
        text-align: left;
      }
      .details p {
        font-size: 12px; 
        margin: 5px 0;
        display: flex;
        justify-content: space-between;
        padding-bottom: 6px;
        border-bottom: 1px solid #d1d1d1;
      }
      .label {
        font-weight: 600;
      }
    </style>
  </head>
  <body>
    <div class="receipt-container">
      <img
        src="https://cdn-icons-png.flaticon.com/512/845/845646.png"
        alt="Success"
        class="success-icon"
      />
      <h2>Payment Success</h2>
      <p class="company-name">D&D IT Network and Data Solutions</p>

      <div class="separator"></div>
      <!-- Added space here -->

      <div class="details">
        <p><span class="label">Account ID:</span> <span>001100</span></p>
        <p><span class="label">Plan:</span> <span>Plan 1400</span></p>
        <p>
          <span class="label">Account Name:</span> <span>Daniel Ruamar</span>
        </p>
        <p>
          <span class="label">Reference Number:</span> <span>20912100000</span>
        </p>
        <p><span class="label">Date:</span> <span>January 05, 2025</span></p>
        <p><span class="label">Amount:</span> <span>PHP 1,400.00</span></p>
      </div>
    </div>
  </body>
</html>
